ontainer_root__Ycg94 container_responsive__hpeZ9"><section class="flex-grid justify-between press_trustedFor__WlOia"><div class="col-1"></div><div class="col-14"><div class="center_root___q8wn center_andText__q9Qi5" style="--center-measure:60ch"><h2 class="text text_text-eyebrow-lg__ux1_s text_text-eyebrow__GDH_m text_text__XCDHr text_text-weight-normal__Zsm0J text_responsive__YZEGi">Trusted for over a decade</h2></div><div class="statCard_statCardCollection__14uOr"><div aria-atomic="true" class="card_card___ZlNq card_elevation50__eBO8I card_radiusMd__MCoYi statCard_statCard__JHVMT"><div class="stack_root__raz5U statCard_cardContent__19aaQ" style="--gap-size:0.5rem"><img src="data:image/svg+xml;base64," loading="lazy" alt=""/><div class="stack_root__raz5U" style="--gap-size:0.25rem;--parent-gap-size:0.5rem"><p class="statCard_number__r958H heading_heading4__4sOza heading_heading__yebkp"><span>3B</span></p><p class="text text_text-sm__fJ7Aa text_text__XCDHr text_text-weight-normal__Zsm0J statCard_title__4MLZC">Monthly Searches</p><p class="text text_text-xs__IOlJx text_text__XCDHr text_text-weight-normal__Zsm0J statCard_description__iwAXM">And Growing Fast</p></div></div></div><div aria-atomic="true" class="card_card___ZlNq card_elevation50__eBO8I card_radiusMd__MCoYi statCard_statCard__JHVMT"><div class="stack_root__raz5U statCard_cardContent__19aaQ" style="--gap-size:0.5rem"><img src="data:image/svg+xml;base64," loading="lazy" alt=""/><div class="stack_root__raz5U" style="--gap-size:0.25rem;--parent-gap-size:0.5rem"><p class="statCard_number__r958H heading_heading4__4sOza heading_heading__yebkp"><span>9M</span></p><p class="text text_text-sm__fJ7Aa text_text__XCDHr text_text-weight-normal__Zsm0J statCard_title__4MLZC">Monthly Downloads</p><p class="text text_text-xs__IOlJx text_text__XCDHr text_text-weight-normal__Zsm0J statCard_description__iwAXM">On Mobile &amp; Desktop</p></div></div></div><div aria-atomic="true" class="card_card___ZlNq card_elevation50__eBO8I card_radiusMd__MCoYi statCard_statCard__JHVMT"><div class="stack_root__raz5U statCard_cardContent__19aaQ" style="--gap-size:0.5rem"><img src="data:image/svg+xml;base64," loading="lazy" alt=""/><div class="stack_root__raz5U" style="--gap-size:0.25rem;--parent-gap-size:0.5rem"><p class="statCard_number__r958H statCard_rating__ZqAdJ heading_heading4__4sOza heading_heading__yebkp"><span>4.8<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 13 13" aria-hidden="true"><path fill="currentColor" d="m6.684.901 1.418 4.496h4.589L8.979 8.175l1.418 4.495-3.713-2.778-3.712 2.778L4.39 8.175.678 5.397h4.588L6.684.9Z"></path></svg></span></p><p class="text text_text-sm__fJ7Aa text_text__XCDHr text_text-weight-normal__Zsm0J statCard_title__4MLZC">Average Rating</p><p class="text text_text-xs__IOlJx text_text__XCDHr text_text-weight-normal__Zsm0J statCard_description__iwAXM">On Apple &amp; Google Play</p></div></div></div><div aria-atomic="true" class="card_card___ZlNq card_elevation50__eBO8I card_radiusMd__MCoYi statCard_statCard__JHVMT"><div class="stack_root__raz5U statCard_cardContent__19aaQ" style="--gap-size:0.5rem"><img src="data:image/svg+xml;base64," loading="lazy" alt=""/><div class="stack_root__raz5U" style="--gap-size:0.25rem;--parent-gap-size:0.5rem"><p class="statCard_number__r958H heading_heading4__4sOza heading_heading__yebkp"><span>$8.05M</span></p><p class="text text_text-sm__fJ7Aa text_text__XCDHr text_text-weight-normal__Zsm0J statCard_title__4MLZC">Donated</p><p class="text text_text-xs__IOlJx text_text__XCDHr text_text-weight-normal__Zsm0J statCard_description__iwAXM">To Advance Privacy</p></div></div></div></div></div><div class="col-1"></div></section></div><div class="container_root__Ycg94 container_responsive__hpeZ9"><div class="content_root___2bzn"><section class="press_since2008__hVVbE"><div class="center_root___q8wn center_andText__q9Qi5" style="--center-measure:60ch"><div class="stack_root__raz5U" style="--gap-size:1.5rem"><p class="text text_text-lg__oLfYk text_text__XCDHr text_text-weight-normal__Zsm0J text_responsive__YZEGi">Since 2008, we&#x27;ve created new technology, donated to organizations, and worked with policymakers to make online protection simple and accessible for all.</p><p class="text text_text-lg__oLfYk text_text__XCDHr text_text-weight-normal__Zsm0J text_responsive__YZEGi">To date, we&#x27;ve grown into a fully distributed team of more than <!-- -->335<!-- --> passionate individuals from over 15 countries.</p></div></div></section></div></div><section class="press_blog__ugneo"><div class="container_root__Ycg94 container_responsive__hpeZ9"><div class="content_root___2bzn"><div class="center_root___q8wn center_andText__q9Qi5" style="--center-measure:52ch"><h2 class="heading_heading3__N45OF heading_heading__yebkp heading_responsive__lDUe2">From our Blog</h2></div></div></div><div class="press_postsContainer__yL84I"><div class="press_postsWrapper__dQ_rF container_root__Ycg94 container_responsive__hpeZ9"><div class="blogPosts_cards__j2DpN"></div></div></div></section><section class="press_pressMaterials__pT8ZY"><a id="press-materials"></a><div class="container_root__Ycg94 container_responsive__hpeZ9"><div class="content_root___2bzn"><div class="center_root___q8wn center_andText__q9Qi5" style="--center-measure:52ch"><h2 class="heading_heading3__N45OF heading_heading__yebkp heading_responsive__lDUe2">Press Materials</h2></div></div><div class="flex-grid justify-between"><div class="col-1"></div><div class="col-14"><div class="content_root___2bzn press_cards__rLmER"><article class="center_root___q8wn center_andText__q9Qi5" style="--center-measure:none"><svg xmlns="http://www.w3.org/2000/svg" width="99.329" height="87.752" fill="none" viewBox="6 14.685 74 56.051" style="margin-left:-20px"><path stroke="#aaa" stroke-linecap="round" stroke-opacity="0.6" stroke-width="3" d="m15.517 13.902-4.013-3.03M13.505 20.468H7.5"></path><g fill-rule="evenodd" clip-rule="evenodd"><path fill="#aaa" fill-opacit