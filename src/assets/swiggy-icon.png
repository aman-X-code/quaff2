0 1 1.384 0l5.468 5.523a.994.994 0 0 1 0 1.398l-.574.58a.971.971 0 0 1-1.384 0"></path><path fill="#de5833" d="m68.245 64.357 5.468-5.522a.994.994 0 0 0 0-1.398l-.574-.58a.97.97 0 0 0-1.384 0l-5.468 5.523a.994.994 0 0 0 0 1.398l.574.58a.971.971 0 0 0 1.384 0"></path></g></svg><h3 class="heading_heading4__4sOza heading_heading__yebkp heading_responsive__lDUe2">Brand Assets</h3><p class="text text_text-sm__fJ7Aa text_text__XCDHr text_text-weight-normal__Zsm0J text_responsive__YZEGi press_description__IIpsw">Access our logo and brand guidelines.</p><a href="https://staticcdn.duckduckgo.com/press/DuckDuckGo-Brand-Logo.zip"><button class="button_button__GGtY1 button_primary__bqhFV button_size-md__1jSxL">Download</button></a><p class="text text_text-xs__IOlJx text_text__XCDHr text_text-weight-normal__Zsm0J text_responsive__YZEGi">The DuckDuckGo name, logos, trade dress, and other brand elements are trademarks of Duck Duck Go, Inc.</p></article><article class="center_root___q8wn center_andText__q9Qi5" style="--center-measure:none"><svg xmlns="http://www.w3.org/2000/svg" width="97.111" height="85.139" fill="none" viewBox="13 18 72.891 64"><mask id="_R_daj6_photos_svg__a" width="28" height="15" x="45" y="54" maskUnits="userSpaceOnUse"><path fill="#fff" fill-rule="evenodd" d="M45.828 54.828H73v13.173H45.828z" clip-rule="evenodd"></path></mask><mask id="_R_daj6_photos_svg__b" width="32" height="21" x="29" y="48" maskUnits="userSpaceOnUse"><path fill="#fff" fill-rule="evenodd" d="M29 48.828h31.172v19.173H29z" clip-rule="evenodd"></path></mask><g fill-rule="evenodd" clip-rule="evenodd"><path fill="#aaa" fill-opacity="0.3" d="M47.914 78h34V52h-34zm34-30h-34a4 4 0 0 0-4 4v26a4 4 0 0 0 4 4h34a4 4 0 0 0 4-4V52a4 4 0 0 0-4-4z"></path><path fill="#aaa" fill-opacity="0.3" d="M16.914 48h34V22h-34zm34-30h-34a4 4 0 0 0-4 4v26a4 4 0 0 0 4 4h34a4 4 0 0 0 4-4V22a4 4 0 0 0-4-4z"></path><path fill="#8fabf9" d="M25.914 70h48V30h-48z"></path></g><g mask="url(#_R_daj6_photos_svg__a)" transform="t